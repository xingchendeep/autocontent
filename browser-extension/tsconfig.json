{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": false,
    "skipLibCheck": true
  },
  "include": ["content/**/*.ts", "popup/**/*.ts", "background/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
